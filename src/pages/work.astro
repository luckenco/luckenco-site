---
import WorkCard from "../components/work-card.astro";
import { currentlyInvolved, pastProjects } from "../data/work";
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout>
    <div class="work-container">
        <a href="/" class="back-link">← home</a>
        <h1>work</h1>

        <section class="work-section cta-section">
            <p>
                Taking on select projects: AI systems, automation pipelines,
                and production-grade software.
            </p>
            <a
                href="https://cal.com/luckenbach/quick-chat"
                target="_blank"
                rel="noopener">Book a call →</a
            >
        </section>

        <section class="work-section">
            <h2>Currently Involved</h2>
            <div class="work-list">
                {currentlyInvolved.map((item) => <WorkCard {...item} />)}
            </div>
        </section>

        <section class="work-section">
            <h2>Past Projects</h2>
            <div class="work-list">
                {pastProjects.map((item) => <WorkCard {...item} />)}
            </div>
        </section>

        <section class="work-section">
            <h2>Partners & Organizations</h2>
            <div class="partner-list">
                <div class="partner-item">
                    <span class="partner-name">adler.studio</span>
                    <p>
                        Vienna-based product studio building standout digital
                        products across web, native, and 3D.
                    </p>
                    <a
                        href="https://www.adler.studio/?ref=luckenbach"
                        target="_blank"
                        rel="noopener">Visit adler.studio →</a
                    >
                </div>
                <div class="partner-item">
                    <span class="partner-name">steig</span>
                    <p>
                        AI transformation, company-wide tool adoption, and EU
                        AI Act preparation for decision makers.
                    </p>
                    <a
                        href="https://steig.co?ref=luckenco"
                        target="_blank"
                        rel="noopener">Visit steig →</a
                    >
                </div>
            </div>
        </section>
    </div>
</BaseLayout>

<style>
    .back-link {
        position: absolute;
        top: 2rem;
        left: 2rem;
        color: black;
    }

    .work-container {
        width: 90%;
        max-width: 740px;
        margin: 0 auto;
        padding: 1rem;
    }

    h1 {
        font-size: 1.6rem;
        letter-spacing: -2px;
        margin: 0.5rem 0 2rem;
        text-align: center;
    }

    h2 {
        font-size: 1.2rem;
        margin: 2rem 0 1rem;
    }

    .cta-section p,
    .partner-item p {
        font-size: 0.9rem;
        line-height: 1.5;
        margin: 0.5rem 0;
    }

    .work-section {
        margin: 2rem 0;
    }

    .work-list,
    .partner-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .partner-item {
        padding: 1rem;
        border: 1px solid black;
    }

    .partner-name {
        font-weight: bold;
    }

    /* Tablet and desktop styles */
    @media (min-width: 768px) {
        h1 {
            font-size: 2rem;
        }

        h2 {
            font-size: 1.4rem;
        }

        .cta-section p,
        .partner-item p {
            font-size: 1rem;
        }

        .work-container {
            padding: 2rem;
        }

        .partner-item {
            padding: 1.5rem;
        }
    }
</style>
