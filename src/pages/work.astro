---
import WorkCard from "../components/work-card.astro";
import { partners, projects } from "../data/work";
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout>
    <div class="work-container">
        <a href="/" class="page-back-link back-link">← home</a>
        <h1>work</h1>

        <section class="work-section cta-section">
            <p>
                Taking on select projects in AI systems, automation, and
                software that has to work under real production constraints.
            </p>
            <a
                href="https://cal.com/luckenbach/quick-chat"
                target="_blank"
                rel="noopener">Book a call →</a
            >
        </section>

        <section class="work-section">
            <h2>Projects</h2>
            <div class="work-list">
                {projects.map((item) => <WorkCard {...item} />)}
            </div>
        </section>

        <section class="work-section">
            <h2>Partners & Organizations</h2>
            <div class="work-list">
                {partners.map((item) => <WorkCard {...item} />)}
            </div>
        </section>
    </div>
</BaseLayout>

<style>
    .back-link {
        position: absolute;
        top: 2rem;
        left: 2rem;
    }

    .work-container {
        width: min(100%, 56rem);
        margin: 0 auto;
    }

    h1 {
        font-size: clamp(2.2rem, 4vw, 2.9rem);
        margin: 0 0 1.25rem;
    }

    h2 {
        font-size: clamp(1.35rem, 1.5vw, 1.75rem);
        margin: 0 0 1.25rem;
    }

    .cta-section p {
        max-width: var(--measure-compact);
        font-size: var(--font-size-body-lg);
        line-height: 1.75;
        margin: 0 0 1rem;
    }

    .cta-section a {
        font-family: var(--font-mono);
        font-size: var(--font-size-utility);
        letter-spacing: -0.015em;
    }

    .work-section {
        margin: 0 0 3rem;
    }

    .work-list {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        align-items: start;
    }

    /* Tablet and desktop styles */
    @media (min-width: 768px) {
        .work-container {
            padding-top: 0.5rem;
        }

        .work-list {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .work-list :global(.work-card--with-image) {
            grid-column: span 2;
        }
    }

    @media (max-width: 640px) {
        .back-link {
            position: static;
            display: block;
            margin-bottom: 1.5rem;
        }
    }
</style>
