---
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout>
    <div class="work-container">
        <a href="/" class="back-link">← home</a>
        <h1>work</h1>

        <section class="work-section cta-section">
            <p>
                Taking on select projects: AI systems, automation pipelines,
                and production-grade software.
            </p>
            <a
                href="https://cal.com/luckenbach/quick-chat"
                target="_blank"
                rel="noopener">Book a call →</a
            >
        </section>

        <section class="work-section">
            <h2>Currently Involved</h2>
            <div class="work-list">
                <div class="work-item">
                    <h3>The Vienna AI Company</h3>
                    <p>
                        On LISA, I cut average end-to-end call-system response
                        latency by 70% and built agentic voice capabilities
                        across LiveKit, Gemini, and ElevenLabs.
                    </p>
                    <a
                        href="https://lisa.aicompany.at/"
                        target="_blank"
                        rel="noopener">Visit LISA →</a
                    >
                </div>
                <div class="work-item">
                    <h3>VERTEX</h3>
                    <p>
                        Building automation workflows for Vertex, a
                        retail engineering company operating across physical
                        and digital product experiences.
                    </p>
                    <a
                        href="https://www.vertex.de/en/"
                        target="_blank"
                        rel="noopener">Visit Vertex →</a
                    >
                </div>
                <div class="work-item">
                    <h3>shapeID</h3>
                    <p>
                        Building 3D body-scanning systems that turn mobile
                        capture and scan data into measurement and fit
                        workflows for apparel.
                    </p>
                    <a
                        href="https://shapeid.io/?ref=luckenco"
                        target="_blank"
                        rel="noopener">Visit shapeID →</a
                    >
                </div>
                <div class="work-item">
                    <h3>rsai.dev</h3>
                    <p>
                        Predictable development for unpredictable models. Let
                        the compiler handle the chaos. Minimal Rust framework to
                        interact with LLMs.
                    </p>
                    <a
                        href="https://rsai.dev?ref=luckenco"
                        target="_blank"
                        rel="noopener">View code →</a
                    >
                </div>
            </div>
        </section>

        <section class="work-section">
            <h2>Past Projects</h2>
            <div class="work-list">
                <div class="work-item">
                    <h3>Invoice Automation</h3>
                    <p>
                        Delivered 120% year-one ROI, eliminated 525 hours of
                        manual work, and reduced data-entry errors by 78% with
                        an async invoice-processing pipeline built in Rust and
                        Azure AI.
                    </p>
                </div>
                <div class="work-item">
                    <h3>Sales-to-CRM AI Agent</h3>
                    <p>
                        Cut lead entry time by more than 80%, bringing each
                        interaction under 1 minute by turning unstructured
                        field notes into structured CRM entities.
                    </p>
                    <a
                        href="https://steig.co?ref=luckenco"
                        target="_blank"
                        rel="noopener">Visit steig →</a
                    >
                </div>
                <div class="work-item">
                    <h3>Real Estate Deduplication Pipeline</h3>
                    <p>
                        Built a deduplication pipeline for nationwide Swiss
                        property data, reducing record overlap by nearly 90%
                        and processing time by over 65%.
                    </p>
                </div>
                <div class="work-item">
                    <h3>SteriScan</h3>
                    <p>
                        Reduced the risk of 2-week regulatory shutdowns with a
                        tamper-proof sterilization tracking system that enforced
                        QM-compliant clinical workflows through NFC
                        authentication.
                    </p>
                </div>
                <div class="work-item">
                    <h3>3D Motorcycle Configurator</h3>
                    <p>
                        Enabled real-time, in-browser customization of 50+
                        vehicle parts with sub-2-second rendering latency
                        using hardware-accelerated WebGL.
                    </p>
                </div>
                <div class="work-item inactive-work">
                    <h3>lenge</h3>
                    <p>
                        Lenge uses AI to recommend personalized habits based on
                        your goals and energy levels. We then match you with an
                        accountability partner who shares similar ambitions.
                        Together, you embark on a 14-day challenge, supporting
                        and motivating each other along the way.
                    </p>
                    <a
                        href="https://lenge.club?ref=luckenco"
                        target="_blank"
                        rel="noopener">Visit lenge →</a
                    >
                </div>
            </div>
        </section>

        <section class="work-section">
            <h2>Partners & Organizations</h2>
            <div class="partner-list">
                <div class="partner-item">
                    <span class="partner-name">adler.studio</span>
                    <p>
                        Vienna-based product studio building standout digital
                        products across web, native, and 3D.
                    </p>
                    <a
                        href="https://www.adler.studio/?ref=luckenbach"
                        target="_blank"
                        rel="noopener">Visit adler.studio →</a
                    >
                </div>
                <div class="partner-item">
                    <span class="partner-name">steig</span>
                    <p>
                        AI transformation, company-wide tool adoption, and EU
                        AI Act preparation for decision makers.
                    </p>
                    <a
                        href="https://steig.co?ref=luckenco"
                        target="_blank"
                        rel="noopener">Visit steig →</a
                    >
                </div>
            </div>
        </section>
    </div>
</BaseLayout>

<style>
    .back-link {
        position: absolute;
        top: 2rem;
        left: 2rem;
        color: black;
    }

    .work-container {
        width: 90%;
        max-width: 740px;
        margin: 0 auto;
        padding: 1rem;
    }

    h1 {
        font-size: 1.6rem;
        letter-spacing: -2px;
        margin: 0.5rem 0 2rem;
        text-align: center;
    }

    h2 {
        font-size: 1.2rem;
        margin: 2rem 0 1rem;
    }

    h3 {
        font-size: 1.1rem;
        margin: 0 0 0.5rem;
    }

    p {
        font-size: 0.9rem;
        line-height: 1.5;
        margin: 0.5rem 0;
    }

    .work-section {
        margin: 2rem 0;
    }

    .work-list,
    .partner-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .work-item,
    .partner-item {
        padding: 1rem;
        border: 1px solid black;
    }

    .inactive-work {
        border-style: dashed;
    }

    .partner-name {
        font-weight: bold;
    }

    /* Tablet and desktop styles */
    @media (min-width: 768px) {
        h1 {
            font-size: 2rem;
        }

        h2 {
            font-size: 1.4rem;
        }

        h3 {
            font-size: 1.2rem;
        }

        p {
            font-size: 1rem;
        }

        .work-container {
            padding: 2rem;
        }

        .work-item,
        .partner-item {
            padding: 1.5rem;
        }
    }
</style>
