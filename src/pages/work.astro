---
import WorkCard from "../components/work-card.astro";
import { partners, projects } from "../data/work";
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout>
    <div class="work-container">
        <a href="/" class="back-link">← home</a>
        <h1>work</h1>

        <section class="work-section cta-section">
            <p>
                Taking on select projects in AI systems, automation, and
                software that has to work under real production constraints.
            </p>
            <a
                href="https://cal.com/luckenbach/quick-chat"
                target="_blank"
                rel="noopener">Book a call →</a
            >
        </section>

        <section class="work-section">
            <h2>Projects</h2>
            <div class="work-list">
                {projects.map((item) => <WorkCard {...item} />)}
            </div>
        </section>

        <section class="work-section">
            <h2>Partners & Organizations</h2>
            <div class="work-list">
                {partners.map((item) => <WorkCard {...item} />)}
            </div>
        </section>
    </div>
</BaseLayout>

<style>
    .back-link {
        position: absolute;
        top: 2rem;
        left: 2rem;
        color: black;
    }

    .work-container {
        width: 90%;
        max-width: 740px;
        margin: 0 auto;
        padding: 1rem;
    }

    h1 {
        font-size: 1.6rem;
        margin: 0.5rem 0 2rem;
        text-align: center;
    }

    h2 {
        font-size: 1.2rem;
        margin: 2rem 0 1rem;
    }

    .cta-section p {
        font-size: 0.9rem;
        line-height: 1.5;
        margin: 0.5rem 0;
    }

    .work-section {
        margin: 2rem 0;
    }

    .work-list {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        align-items: start;
    }

    /* Tablet and desktop styles */
    @media (min-width: 768px) {
        h1 {
            font-size: 2rem;
        }

        h2 {
            font-size: 1.4rem;
        }

        .cta-section p {
            font-size: 1rem;
        }

        .work-container {
            padding: 2rem;
        }

        .work-list {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .work-list :global(.work-card--with-image) {
            grid-column: span 2;
        }
    }
</style>
