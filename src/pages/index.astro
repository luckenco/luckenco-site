---
import { Image } from "astro:assets";
import avatar from "../assets/avatar.webp";
import { projects } from "../data/work";
import BaseLayout from "../layouts/base-layout.astro";

const projectById = new Map(projects.map((project) => [project.id, project]));

const getProject = (id: string) => {
  const project = projectById.get(id);

  if (!project) {
    throw new Error(`Missing project data for ${id}`);
  }

  return project;
};

const selectedProjectIds = [
  "vienna-ai-company",
  "invoice-automation",
  "real-estate-dedup",
] as const;

const selectedProjects = selectedProjectIds.map((id) => getProject(id));

const proofPoints = [
  {
    id: "vienna-ai-company",
    parts: [
      { type: "text", text: "Response times dropped by " },
      { type: "stat", text: "70%" },
      { type: "text", text: "." },
    ],
  },
  {
    id: "invoice-automation",
    parts: [
      { type: "text", text: "Delivered " },
      { type: "stat", text: "120% first-year ROI" },
      { type: "text", text: " and removed " },
      { type: "stat", text: "525 hours" },
      { type: "text", text: " of manual work." },
    ],
  },
  {
    id: "real-estate-dedup",
    parts: [
      { type: "text", text: "Duplicate records dropped by " },
      { type: "stat", text: "nearly 90%" },
      { type: "text", text: ", and processing time fell by " },
      { type: "stat", text: "over 65%" },
      { type: "text", text: "." },
    ],
  },
] as const;
---

<BaseLayout>
    <div class="home-shell">
        <section class="hero" aria-labelledby="home-title">
            <div class="hero-image">
                <div class="avatar-container">
                    <Image
                        src={avatar}
                        alt="Portrait of Constantin Luckenbach"
                        class="avatar-image"
                        width={640}
                        height={640}
                        widths={[208, 320, 416, 640]}
                        loading="eager"
                        fetchpriority="high"
                        sizes="(max-width: 720px) 208px, 320px"
                    />
                </div>
            </div>

            <section class="hero-proof" aria-labelledby="hero-proof-title">
                <h2 id="hero-proof-title" class="sr-only">Selected results</h2>
                <p class="proof-strip-copy">
                    {
                        proofPoints.map((story) => (
                            <span class="proof-story">
                                {story.parts.map((part) => (
                                    <span class:list={[`proof-${part.type}`]}>{part.text}</span>
                                ))}
                            </span>
                        ))
                    }
                </p>
            </section>

            <div class="hero-copy">
                <h1 id="home-title" class="heading">Constantin Luckenbach</h1>
                <p class="hero-lede">I build systems that stay reliable under real-world constraints.</p>
                <p class="hero-support">
                    Recent work includes agentic voice, finance operations automation, and large-scale data pipelines.
                </p>

                <div class="hero-actions">
                    <a
                        class="hero-cta"
                        href="https://cal.com/luckenbach/quick-chat"
                        target="_blank"
                        rel="noopener noreferrer">work together</a
                    >

                    <nav class="hero-primary-links" aria-label="Primary links">
                        <ul class="link-container font-mono">
                            <li>
                                <a href="/writing">writing</a>
                            </li>
                            <li>
                                <a href="/work">work</a>
                            </li>
                        </ul>
                    </nav>
                </div>

                <p class="hero-mobile-proof mono-accent">Avg outcomes: 2.4x ROI, &lt;1 quarter to launch.</p>

                <nav aria-label="Social links">
                    <ul class="social-links">
                        <li>
                            <a href="https://github.com/luckenco" aria-label="GitHub Profile" target="_blank" rel="noopener noreferrer">
                                <svg
                                    width="24"
                                    height="24"
                                    viewBox="0 0 98 96"
                                    xmlns="http://www.w3.org/2000/svg"
                                    aria-hidden="true"
                                    focusable="false"
                                    ><path
                                        fill-rule="evenodd"
                                        clip-rule="evenodd"
                                        d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.141-22.243-5.378-22.243-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z"
                                        fill="currentColor"></path></svg
                                >
                            </a>
                        </li>
                        <li>
                            <a href="https://linkedin.com/in/luckenco" aria-label="LinkedIn Profile" target="_blank" rel="noopener noreferrer">
                                <svg
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    xmlns="http://www.w3.org/2000/svg"
                                    aria-hidden="true"
                                    focusable="false"
                                >
                                    <path
                                        d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                                        fill="currentColor"></path>
                                </svg>
                            </a>
                        </li>
                        <li>
                            <a href="https://youtube.com/@luckenco" aria-label="YouTube Channel" target="_blank" rel="noopener noreferrer">
                                <svg
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    xmlns="http://www.w3.org/2000/svg"
                                    aria-hidden="true"
                                    focusable="false"
                                >
                                    <path
                                        d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                                        fill="currentColor"></path>
                                </svg>
                            </a>
                        </li>
                        <li>
                            <a href="https://instagram.com/luckenco" aria-label="Instagram Profile" target="_blank" rel="noopener noreferrer">
                                <svg
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    xmlns="http://www.w3.org/2000/svg"
                                    aria-hidden="true"
                                    focusable="false"
                                >
                                    <path
                                        d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                                        fill="currentColor"></path>
                                </svg>
                            </a>
                        </li>
                        <li>
                            <a href="https://x.com/luckenco" aria-label="X Profile" target="_blank" rel="noopener noreferrer">
                                <svg
                                    width="22"
                                    height="22"
                                    viewBox="0 0 1200 1227"
                                    fill="none"
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="lucide lucide-x"
                                    aria-hidden="true"
                                    focusable="false"
                                >
                                    <path
                                        d="M714.163 519.284L1160.89 0H1055.03L667.137 450.887L357.328 0H0L468.492 681.821L0 1226.37H105.866L515.491 750.218L842.672 1226.37H1200L714.137 519.284H714.163ZM569.165 687.828L521.697 619.934L144.011 79.6944H306.615L611.412 515.685L658.88 583.579L1055.08 1150.3H892.476L569.165 687.854V687.828Z"
                                        fill="currentColor"></path>
                                </svg>
                            </a>
                        </li>
                    </ul>
                </nav>

                <p class="hero-mobile-writing">
                    You might also like my <a href="/writing">writing</a>.
                </p>
            </div>
        </section>

        <section class="selected-work" aria-labelledby="selected-work-title">
            <div class="selected-work-header">
                <p class="selected-work-kicker mono-accent">Selected work</p>
                <h2 id="selected-work-title">Outcomes from recent projects.</h2>
            </div>

            <ul class="selected-work-list">
                {
                    selectedProjects.map((project, index) => (
                        <li class:list={["selected-work-item", { "selected-work-item--wide": index === 2 }]}>
                            <article>
                                <p class="selected-work-index mono-accent">{String(index + 1).padStart(2, "0")}</p>
                                <h3>{project.title}</h3>
                                <p class="selected-work-description">{project.description}</p>
                                {
                                    project.href && project.linkLabel && (
                                        <a class="selected-work-link" href={project.href} target="_blank" rel="noopener">
                                            {project.linkLabel}
                                        </a>
                                    )
                                }
                            </article>
                        </li>
                    ))
                }
            </ul>

            <p class="mobile-work-link mono-accent">
                <a href="/work">View all work →</a>
            </p>
        </section>
    </div>

</BaseLayout>

<style>
    .home-shell {
        width: min(100%, 68rem);
    }

    .hero {
        display: grid;
        grid-template-columns: minmax(15rem, 20rem) minmax(0, 1fr);
        grid-template-areas:
            "image copy"
            "proof copy";
        column-gap: clamp(2rem, 4vw, 4.5rem);
        row-gap: 1.25rem;
        align-items: start;
    }

    .hero-image {
        grid-area: image;
        display: flex;
        justify-content: center;
    }

    .hero-copy {
        grid-area: copy;
        text-align: left;
    }

    .heading {
        font-family: var(--font-sans);
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .avatar-container {
        width: min(100%, 20rem);
        aspect-ratio: 1 / 1;
        position: relative;
        margin: 0 auto;
    }

    .avatar-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 30%;
        border-radius: 18px;
    }

    h1 {
        font-size: clamp(2.45rem, 4.55vw, 3.85rem);
        letter-spacing: -0.04em;
    }

    .hero-lede {
        max-width: 19ch;
        font-size: clamp(1.2rem, 1.02vw + 1rem, 1.52rem);
        line-height: 1.32;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
    }

    .hero-support {
        max-width: 34rem;
        font-size: var(--font-size-body-lg);
        line-height: 1.66;
        color: var(--fg-muted);
        margin-bottom: 1.35rem;
    }

        .hero-mobile-proof {
        display: none;
        margin: 0 0 0.9rem;
        color: var(--fg-muted);
        text-wrap: pretty;
    }

    .hero-proof {
        grid-area: proof;
        width: min(100%, 20rem);
        margin: 0 auto;
    }

    .proof-strip-copy {
        margin: 0;
        font-family: var(--font-sans);
        font-size: clamp(1.02rem, 0.62vw + 0.98rem, 1.28rem);
        line-height: 1.26;
        letter-spacing: -0.02em;
        color: var(--fg-muted);
    }

    .proof-story {
        display: inline;
    }

    .proof-story:not(:last-child)::after {
        content: " ";
    }

    .proof-text {
        color: inherit;
    }

    .proof-stat {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.88em;
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.02em;
        color: var(--fg);
        white-space: nowrap;
    }

    ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    li {
        margin: 0;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 1rem 1.5rem;
        margin-bottom: 0.95rem;
    }

    .hero-cta {
        display: inline-flex;
        align-items: center;
        min-height: 2.85rem;
        padding: 0.7rem 1.1rem;
        border: 1px solid var(--border);
        border-bottom-width: 1px;
        font-family: var(--font-mono);
        font-size: var(--font-size-utility);
        letter-spacing: -0.015em;
        line-height: 1;
    }

    .hero-cta:hover {
        border-bottom-width: 1px;
        background: #f6f6f6;
    }

    .link-container {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem 1.25rem;
        align-items: center;
        font-size: var(--font-size-utility);
        line-height: 1.5;
        letter-spacing: -0.015em;
    }

    .link-container a {
        border-bottom-width: 1px;
    }

    .social-links {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
        justify-content: flex-start;
        align-items: center;
    }

    .social-links a {
        color: inherit;
        border-bottom: none;
        opacity: 0.85;
        transition: opacity 0.2s ease;
    }

    .social-links a:hover {
        opacity: 1;
    }

    .hero-mobile-writing {
        display: none;
    }

    .selected-work {
        margin-top: clamp(4.4rem, 9.5vw, 6.8rem);
        padding-top: 1.25rem;
        border-top: 1px solid #e8e8e8;
    }

    .selected-work-header {
        max-width: 32rem;
        margin-bottom: 1.5rem;
    }

    .selected-work-kicker {
        margin-bottom: 0.5rem;
        color: var(--fg-muted);
    }

    .selected-work-header h2 {
        font-size: clamp(1.55rem, 2vw, 2.1rem);
        margin-bottom: 0;
    }

    .selected-work-list {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
    }

    .selected-work-item {
        border: 1px solid #e3e3e3;
        padding: 1.1rem 1.1rem 1.2rem;
    }

    .selected-work-item--wide {
        grid-column: 1 / -1;
    }

    .selected-work-index {
        margin-bottom: 0.7rem;
        color: var(--fg-muted);
    }

    .selected-work-item h3 {
        font-size: clamp(1.2rem, 1.3vw, 1.45rem);
        margin-bottom: 0.7rem;
    }

    .selected-work-description {
        margin-bottom: 0;
        color: var(--fg-muted);
        line-height: 1.68;
        max-width: 48ch;
    }

    .selected-work-link {
        display: inline-flex;
        margin-top: 1rem;
        font-family: var(--font-mono);
        font-size: var(--font-size-utility);
        letter-spacing: -0.015em;
    }

    .mobile-work-link {
        display: block;
        margin-top: 1rem;
        color: var(--fg-muted);
    }

    .mobile-work-link a {
        border-bottom-width: 1px;
    }

    @media (max-width: 640px) {
        .hero {
            grid-template-columns: 1fr;
            grid-template-areas:
                "image"
                "copy";
            gap: 1rem;
        }

        .hero-image {
            justify-content: center;
        }

        .hero-copy {
            text-align: center;
        }

        .avatar-container {
            width: 13rem;
        }

        h1 {
            font-size: clamp(2.1rem, 8.8vw, 2.75rem);
            letter-spacing: -0.035em;
        }

        .hero-lede {
            max-width: 19ch;
            margin-left: auto;
            margin-right: auto;
            margin-bottom: 0.55rem;
        }

        .hero-mobile-proof {
            display: block;
            max-width: 28ch;
            margin: 0.3rem auto 0.55rem;
            font-size: 0.96rem;
            line-height: 1.5;
        }

        .hero-support {
            display: none;
        }

        .hero-proof {
            display: none;
        }

        .hero-actions {
            justify-content: center;
            margin-bottom: 0.65rem;
            gap: 0.85rem 1.1rem;
        }

        .hero-primary-links {
            display: none;
        }

        .social-links {
            justify-content: center;
        }

        .social-links li:nth-child(n + 4) {
            display: none;
        }

        .hero-mobile-writing {
            display: block;
            margin: 0.35rem 0 0;
            text-align: center;
            font-family: var(--font-sans);
            font-size: 1rem;
            line-height: 1.45;
            letter-spacing: -0.01em;
            opacity: 0.62;
        }

        .selected-work {
            margin-top: clamp(3.1rem, 9vw, 4.2rem);
        }

        .selected-work-list {
            grid-template-columns: 1fr;
        }

        .selected-work-item--wide {
            grid-column: auto;
        }
    }

    @media (min-width: 1024px) {
        .hero {
            grid-template-columns: minmax(18rem, 22rem) minmax(0, 1fr);
        }
    }

</style>
