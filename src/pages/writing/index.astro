---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/base-layout.astro";
const posts = await getCollection("blog", ({ data }) => {
  return data.published;
});

posts.sort((a, b) => {
  if (!a.data.publishingDate) {
    return 1;
  }
  if (!b.data.publishingDate) {
    return -1;
  }
  return (
    new Date(b.data.publishingDate).getTime() -
    new Date(a.data.publishingDate).getTime()
  );
});
---

<BaseLayout title="Writing | @luckenco" description="this is where you can find my writing and explorations.">
    <div class="writing-index">
        <a href="/" class="page-back-link back-link">← home</a>
        <h1>writing</h1>
        <ul class="writing-list">
            {posts.map(post => (
            <li>
                <a href={`/writing/${post.id}`}>{post.data.title}</a>
            </li>
            ))}
        </ul>
    </div>
</BaseLayout>

<style>
    .writing-index {
        width: min(100%, 40rem);
    }

    .back-link {
        margin-bottom: 1.5rem;
    }

    h1 {
        font-size: clamp(2rem, 4vw, 2.75rem);
        margin-bottom: 1.5rem;
    }

    .writing-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .writing-list li {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        padding: 0.7rem 0;
        border-bottom: 1px solid #ececec;
    }

    .writing-list li:before {
        content: ">";
        color: var(--fg-muted);
        font-family: var(--font-mono);
        font-size: var(--font-size-meta);
        letter-spacing: -0.015em;
    }

    .writing-list li a {
        text-decoration: none;
        color: inherit;
        border-bottom: 1px solid transparent;
        font-size: clamp(1.05rem, 1vw + 0.95rem, 1.2rem);
        font-weight: 500;
        letter-spacing: -0.02em;
    }

    .writing-list li a:hover {
        border-bottom-color: var(--border);
    }

    @media (max-width: 640px) {
        .writing-index {
            width: min(100%, 21rem);
        }
    }
</style>
