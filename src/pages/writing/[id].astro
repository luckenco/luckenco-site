---
import { getCollection, render } from "astro:content";
import BlogLayout from "../../layouts/blog-layout.astro";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) => {
  return date.toISOString().split("T")[0];
};
---

<BlogLayout title={`${post.data.title} | @luckenco`} description={post.data.description}>
    <article>
        <header>
            <h1 class="heading">{post.data.title}</h1>
            <h2 class="subheading">{post.data.description}</h2>
            <div class="metadata">
                <time datetime={post.data.publishingDate.toISOString()}>
                    {formatDate(post.data.publishingDate)}
                </time>
                {
                    post.data.updateDate && (
                        <time class="update" datetime={post.data.updateDate.toISOString()}>
                            (updated: {formatDate(post.data.updateDate)})
                        </time>
                    )
                }
            </div>
        </header>
        <section class="content">
            <Content />
        </section>
    </article>
</BlogLayout>

<style>
    header {
        margin-bottom: 3.5rem;
        text-align: center;
    }

    .heading {
        font-size: 2rem;
        letter-spacing: -2px;
        margin: 0;
    }

    .subheading {
        font-size: 1.2rem;
        font-weight: normal;
        margin: 1rem 0;
        color: #555;
    }

    .metadata {
        font-size: 0.9rem;
        color: #666;
        margin-top: 1.25rem;
        font-family: var(--font-mono);
    }

    .update {
        margin-left: 0.5rem;
    }

    .content {
        line-height: 1.75;
    }

    .content :global(h1),
    .content :global(h2),
    .content :global(h3),
    .content :global(h4),
    .content :global(h5),
    .content :global(h6) {
        margin: 2rem 0 1rem;
        line-height: 1.25;
    }

    .content :global(p) {
        margin: 0.6rem 0 0.9rem;
    }

    .content :global(ul),
    .content :global(ol) {
        margin: 0.5rem 0 1.25rem;
        padding-left: 1.25rem;
    }

    .content :global(blockquote) {
        margin: 1.5rem 0;
    }

    .content :global(pre),
    .content :global(picture),
    .content :global(img) {
        margin: 1.25rem 0;
        width: 100%;
    }

    .content :global(h1) {
        font-size: 1.8rem;
        font-family: var(--font-mono);
    }

    .content :global(h2),
    .content :global(h3),
    .content :global(h4),
    .content :global(h5),
    .content :global(h6) {
        font-family: var(--font-mono);
    }

    .content :global(h2) {
        font-size: 1.4em;
    }

    .content :global(code),
    .content :global(pre) {
        font-family: var(--font-mono);
    }

    @media (max-width: 480px) {
        .heading {
            font-size: 1.8rem;
        }

        .subheading {
            font-size: 1rem;
        }

        header {
            margin-bottom: 1rem;
        }

        .content {
            padding: 1rem 1rem 4rem;
        }

        .content :global(h1) {
            font-size: 1.2rem;
        }

        .content :global(h2) {
            font-size: 1em;
        }

        .metadata {
            display: flex;
            flex-direction: column;
        }
    }
</style>
