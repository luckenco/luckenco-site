---
import { getCollection, render } from "astro:content";
import BlogLayout from "../../layouts/blog-layout.astro";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) => {
  return date.toISOString().split("T")[0];
};
---

<BlogLayout title={`${post.data.title} | @luckenco`} description={post.data.description}>
    <article>
        <header>
            <h1 class="heading">{post.data.title}</h1>
            <h2 class="subheading">{post.data.description}</h2>
            <div class="metadata">
                <time datetime={post.data.publishingDate.toISOString()}>
                    {formatDate(post.data.publishingDate)}
                </time>
                {
                    post.data.updateDate && (
                        <time class="update" datetime={post.data.updateDate.toISOString()}>
                            (updated: {formatDate(post.data.updateDate)})
                        </time>
                    )
                }
            </div>
        </header>
        <section class="content">
            <Content />
        </section>
    </article>
</BlogLayout>

<style>
    header {
        margin-bottom: 3rem;
        text-align: left;
    }

    .heading {
        font-size: clamp(2.35rem, 5vw, 3.4rem);
        letter-spacing: -0.05em;
        margin: 0 0 1rem;
        max-width: 14ch;
    }

    .subheading {
        max-width: var(--measure-compact);
        font-size: clamp(1.1rem, 1vw + 1rem, 1.35rem);
        font-weight: 400;
        line-height: 1.65;
        margin: 0 0 1.25rem;
        color: var(--fg-muted);
    }

    .metadata {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
        font-size: var(--font-size-meta);
        color: var(--fg-muted);
        margin-top: 0;
        font-family: var(--font-mono);
        letter-spacing: -0.015em;
    }

    .update {
        margin-left: 0;
    }

    .content {
        width: 100%;
        font-size: var(--font-size-body-lg);
        line-height: 1.8;
    }

    .content :global(h1),
    .content :global(h2),
    .content :global(h3),
    .content :global(h4),
    .content :global(h5),
    .content :global(h6) {
        margin: 2.75rem 0 1rem;
        line-height: 1.18;
        letter-spacing: -0.03em;
        font-family: var(--font-sans);
    }

    .content :global(p) {
        margin: 0 0 1.15rem;
        max-width: none;
    }

    .content :global(ul),
    .content :global(ol) {
        margin: 0 0 1.5rem;
        padding-left: 1.35rem;
    }

    .content :global(blockquote) {
        margin: 2rem 0;
        font-size: 1.04em;
    }

    .content :global(pre),
    .content :global(picture),
    .content :global(img) {
        margin: 1.25rem 0;
        width: 100%;
    }

    .content :global(h1) {
        font-size: clamp(1.65rem, 2vw, 2rem);
    }

    .content :global(h2),
    .content :global(h3),
    .content :global(h4),
    .content :global(h5),
    .content :global(h6) {
        font-family: var(--font-sans);
    }

    .content :global(h2) {
        font-size: clamp(1.35rem, 1.4vw + 1rem, 1.8rem);
    }

    .content :global(h3) {
        font-size: clamp(1.18rem, 1vw + 1rem, 1.4rem);
    }

    .content :global(li) {
        margin-bottom: 0.55rem;
        line-height: 1.75;
    }

    .content :global(code),
    .content :global(pre) {
        font-family: var(--font-mono);
    }

    @media (max-width: 480px) {
        .heading {
            font-size: clamp(2rem, 10vw, 2.5rem);
        }

        .subheading {
            font-size: 1rem;
        }

        header {
            margin-bottom: 2rem;
        }

        .content :global(h1) {
            font-size: 1.45rem;
        }

        .content :global(h2) {
            font-size: 1.25rem;
        }

        .metadata {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
