---
const today = new Date();
---

<footer>
    <div class="legal-links">
        <a href="/impressum">Impressum</a>
        <span class="separator">|</span>
        <a href="/datenschutz">Datenschutz</a>
    </div>
    <div class="copyright">
        &copy; {today.getFullYear()} Constantin Luckenbach. All rights reserved.
    </div>
</footer>
<style>
    footer {
        padding: 1.75rem 1rem 2.5rem;
        border-top: 1px solid #e6e6e6;
        color: var(--fg-muted);
        text-align: center;
        font-family: var(--font-mono);
        font-size: 0.88rem;
        line-height: 1.55;
        letter-spacing: -0.015em;
    }

    .legal-links {
        margin-bottom: 0.45rem;
    }

    .legal-links a {
        color: inherit;
        text-decoration: none;
        border-bottom: none;
    }

    .legal-links a:hover {
        text-decoration: underline;
    }

    .separator {
        margin: 0 0.5rem;
    }

    .copyright {
        max-width: 30rem;
        margin: 0 auto;
        text-wrap: pretty;
    }
</style>
