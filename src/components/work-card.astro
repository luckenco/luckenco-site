---
import type { WorkCardItem } from "../data/work";

export interface Props extends WorkCardItem {}

const {
  id,
  title,
  description,
  href,
  linkLabel,
  inactive = false,
  image,
  imageAlt,
} = Astro.props as Props;
const hasImage = Boolean(image);
---

<article
  id={id}
  class:list={[
    "work-card",
    {
      "work-card--inactive": inactive,
      "work-card--with-image": hasImage,
      "work-card--compact": !hasImage,
    },
  ]}
>
  {image && <img class="work-card__image" src={image} alt={imageAlt ?? `${title} logo`} loading="lazy" />}
  <div class="work-card__content">
    <h3>{title}</h3>
    <p class="font-mono" style="opacity: 0.7;">{description}</p>
    {href && linkLabel && (
      <a class="font-mono" href={href} target="_blank" rel="noopener">{linkLabel}</a>
    )}
  </div>
</article>

<style>
  .work-card {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: stretch;
    padding: 0;
    border: 1px solid black;
    height: 11rem;
    max-height: 11rem;
    min-height: 11rem;
    overflow: hidden;
  }

  .work-card--compact {
    height: auto;
    min-height: 11rem;
    max-height: 11rem;
  }

  .work-card__image {
    flex: 0 0 11rem;
    width: auto;
    height: 100%;
    aspect-ratio: 4 / 5;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .work-card--inactive {
    border-style: dashed;
  }

  .work-card__content {
    flex: 1;
    min-width: 0;
    margin: 1em;
    overflow: hidden;
  }

  .work-card--compact .work-card__content {
    margin: 0.75em 1em;
  }

  h3 {
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
  }

  p {
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0.5rem 0;
  }

  @media (min-width: 768px) {
    .work-card {
      padding: 0;
    }

    .work-card__content {
      margin: 1em;
    }

    h3 {
      font-size: 1.2rem;
    }

    p {
      font-size: 1rem;
    }
  }
</style>
