---
import type { WorkCardItem } from "../data/work";

export interface Props extends WorkCardItem {}

const {
  id,
  title,
  description,
  href,
  linkLabel,
  inactive = false,
  image,
  imageAlt,
} = Astro.props as Props;
const hasImage = Boolean(image);
---

<article
  id={id}
  class:list={[
    "work-card",
    {
      "work-card--inactive": inactive,
      "work-card--with-image": hasImage,
      "work-card--compact": !hasImage,
    },
  ]}
>
  {image && <img class="work-card__image" src={image} alt={imageAlt ?? `${title} logo`} loading="lazy" />}
  <div class="work-card__content">
    <h3>{title}</h3>
    <p>{description}</p>
    {href && linkLabel && (
      <a class="work-card__link" href={href} target="_blank" rel="noopener">{linkLabel}</a>
    )}
  </div>
</article>

<style>
  .work-card {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: stretch;
    padding: 0;
    border: 1px solid black;
    height: 11rem;
    max-height: 11rem;
    min-height: 11rem;
    overflow: hidden;
  }

  .work-card--compact {
    height: auto;
    min-height: 11rem;
    max-height: 11rem;
  }

  .work-card__image {
    flex: 0 0 11rem;
    width: auto;
    height: 100%;
    aspect-ratio: 4 / 5;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .work-card--inactive {
    border-style: dashed;
  }

  .work-card__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
    margin: 1rem;
    overflow: hidden;
  }

  .work-card--compact .work-card__content {
    margin: 1rem;
  }

  h3 {
    font-size: 1.2rem;
    line-height: 1.2;
    letter-spacing: -0.025em;
    margin: 0 0 0.5rem;
  }

  p {
    color: var(--fg-muted);
    font-size: 0.98rem;
    line-height: 1.65;
    margin: 0;
    max-width: none;
  }

  .work-card__link {
    margin-top: auto;
    width: fit-content;
    font-family: var(--font-mono);
    font-size: var(--font-size-utility);
    letter-spacing: -0.015em;
  }

  @media (max-width: 767px) {
    .work-card--with-image {
      flex-direction: column;
      height: auto;
      min-height: 0;
      max-height: none;
    }

    .work-card--with-image .work-card__image {
      flex: 0 0 auto;
      width: 100%;
      height: auto;
      aspect-ratio: auto;
    }
  }

  @media (min-width: 768px) {
    .work-card {
      padding: 0;
    }

    .work-card__content {
      margin: 1em;
    }

    h3 {
      font-size: 1.25rem;
    }

    p {
      font-size: 1rem;
    }
  }
</style>
